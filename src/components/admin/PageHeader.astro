---
export interface Crumb {
  label: string;
  href?: string;
}

export interface Props {
  title: string;
  crumbs?: Crumb[];
}

const { title, crumbs = [] } = Astro.props;
---

<div class="users-page-header">
  <div class="users-page-header-left">
    <h1 class="users-page-title">{title}</h1>
    <nav>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
        {crumbs.map((c) =>
          c.href ? (
            <li class="breadcrumb-item"><a href={c.href}>{c.label}</a></li>
          ) : (
            <li class="breadcrumb-item active">{c.label}</li>
          )
        )}
      </ol>
    </nav>
  </div>
  <div class="users-page-header-right">
    <slot />
  </div>
</div>
