---
import type { UserProfile } from '@/lib/database.types';
import { publicStorageUrl } from '@/utils/storage';

export interface Props {
  user: UserProfile | null;
}

const { user } = Astro.props;
// BUG FIX (Batch 3A-8): `avatar_url` stores a Supabase Storage *path*
// (e.g. "avatar/169...-abc12.jpg"), not a full URL — every other image
// column in the app goes through `publicStorageUrl()` before being used as
// an <img src> (see /admin/blogs/index.astro, ImageUploader.astro, etc).
// This was unused/untested before Batch 3A-8 added the Profile avatar
// upload feature, so the bug never surfaced until now.
const avatarSrc = user?.avatar_url ? publicStorageUrl(Astro.locals.supabase, user.avatar_url) : '/assets-admin/img/profile-img.webp';
---

<header class="header">
  <div class="header-left">
    <a href="/admin/dashboard" class="header-logo">
      <img src="/assets-admin/img/logo.webp" alt="PowerAdmin" />
      <span>TravelTime Admin</span>
    </a>
    <button class="sidebar-toggle" title="Toggle Sidebar">
      <i class="bi bi-list"></i>
    </button>
  </div>

  <div class="header-right d-flex align-items-center gap-2">
    <!-- Theme Toggle -->
    <button class="header-action theme-toggle" title="Toggle Theme">
      <i class="bi bi-moon-stars theme-icon-dark"></i>
      <i class="bi bi-sun theme-icon-light"></i>
    </button>

    <!-- View Website -->
    <a href="/" target="_blank" class="header-action" title="View Website">
      <i class="bi bi-box-arrow-up-right"></i>
    </a>

    <!-- User Dropdown -->
    <div class="header-action dropdown user-dropdown">
      <button class="dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
        <img src={avatarSrc} alt="User" class="avatar" />
        <div class="user-info">
          <span class="user-name">{user?.name ?? 'User'}</span>
          <span class="user-role">{user?.role === 'admin' ? 'Administrator' : 'Editor'}</span>
        </div>
        <i class="bi bi-chevron-down user-arrow"></i>
      </button>
      <div class="dropdown-menu dropdown-menu-end">
        <div class="user-dropdown-header">
          <img src={avatarSrc} alt="User" class="user-dropdown-avatar" />
          <div class="user-dropdown-info">
            <div class="user-dropdown-name">{user?.name ?? 'User'}</div>
            <div class="user-dropdown-email">{user?.email ?? ''}</div>
          </div>
          <span class="user-dropdown-status"></span>
        </div>
        <div class="user-dropdown-body">
          <a class="user-dropdown-item" href="/admin/profile">
            <i class="bi bi-person"></i>
            <span>My Profile</span>
          </a>
          <a class="user-dropdown-item" href="/admin/settings">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
          </a>
        </div>
        <div class="user-dropdown-footer">
          <form action="/api/auth/logout" method="post">
            <button type="submit" class="user-dropdown-item user-dropdown-logout border-0 bg-transparent w-100 text-start">
              <i class="bi bi-box-arrow-right"></i>
              <span>Sign Out</span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</header>
