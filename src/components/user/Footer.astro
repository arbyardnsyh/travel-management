---
import type { SiteSettings } from '@/lib/database.types';

export interface Props {
  settings: SiteSettings | null;
}

const { settings } = Astro.props;
const websiteName = settings?.website_name || 'TravelTime';
const year = new Date().getFullYear();
---

<footer id="footer" class="footer position-relative dark-background">
  <div class="container">
    <div class="row gy-5">
      <div class="col-lg-4">
        <div class="footer-content">
          <a href="/" class="logo d-flex align-items-center mb-4">
            {settings?.logo && <img src={settings.logo} alt={websiteName} />}
            <span class="sitename">{websiteName}</span>
          </a>
          <p class="mb-4">
            {settings?.hero_subtitle || 'Discover unforgettable destinations and book your next adventure with confidence, wherever the journey takes you.'}
          </p>

          <div class="social-links">
            {settings?.facebook && <a href={settings.facebook} target="_blank" rel="noopener"><i class="bi bi-facebook"></i></a>}
            {settings?.instagram && <a href={settings.instagram} target="_blank" rel="noopener"><i class="bi bi-instagram"></i></a>}
            {settings?.youtube && <a href={settings.youtube} target="_blank" rel="noopener"><i class="bi bi-youtube"></i></a>}
            {settings?.whatsapp && (
              <a href={`https://wa.me/${settings.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener"><i class="bi bi-whatsapp"></i></a>
            )}
          </div>
        </div>
      </div>

      <div class="col-lg-2 col-6">
        <div class="footer-links">
          <h4>Explore</h4>
          <ul>
            <li><a href="/destinations"><i class="bi bi-chevron-right"></i> Destinations</a></li>
            <li><a href="/tours"><i class="bi bi-chevron-right"></i> Tours</a></li>
            <li><a href="/gallery"><i class="bi bi-chevron-right"></i> Gallery</a></li>
            <li><a href="/blog"><i class="bi bi-chevron-right"></i> Blog</a></li>
          </ul>
        </div>
      </div>

      <div class="col-lg-2 col-6">
        <div class="footer-links">
          <h4>Company</h4>
          <ul>
            <li><a href="/about"><i class="bi bi-chevron-right"></i> About Us</a></li>
            <li><a href="/faq"><i class="bi bi-chevron-right"></i> FAQ</a></li>
            <li><a href="/testimonials"><i class="bi bi-chevron-right"></i> Testimonials</a></li>
            <li><a href="/contact"><i class="bi bi-chevron-right"></i> Contact</a></li>
          </ul>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="footer-contact">
          <h4>Get in Touch</h4>
          {settings?.address && (
            <div class="contact-item">
              <div class="contact-icon"><i class="bi bi-geo-alt"></i></div>
              <div class="contact-info"><p>{settings.address}</p></div>
            </div>
          )}
          {settings?.phone && (
            <div class="contact-item">
              <div class="contact-icon"><i class="bi bi-telephone"></i></div>
              <div class="contact-info"><p>{settings.phone}</p></div>
            </div>
          )}
          {settings?.email && (
            <div class="contact-item">
              <div class="contact-icon"><i class="bi bi-envelope"></i></div>
              <div class="contact-info"><p>{settings.email}</p></div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-6">
          <div class="copyright">
            <p>© <span>Copyright</span> <strong class="px-1 sitename">{websiteName}</strong> <span>All Rights Reserved</span> {year}</p>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="footer-bottom-links">
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>
