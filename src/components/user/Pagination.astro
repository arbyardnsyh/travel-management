---
export interface Props {
  currentPage: number;
  totalPages: number;
  /** Base path, e.g. "/destinations". Existing query params are preserved except "page". */
  basePath: string;
  searchParams?: URLSearchParams;
}

const { currentPage, totalPages, basePath, searchParams } = Astro.props;

function buildHref(page: number): string {
  const params = new URLSearchParams(searchParams?.toString() ?? '');
  params.set('page', String(page));
  return `${basePath}?${params.toString()}`;
}

// Build a compact page-number list with ellipses, e.g. 1 2 3 4 ... 10
const pages: (number | '...')[] = [];
if (totalPages <= 7) {
  for (let i = 1; i <= totalPages; i++) pages.push(i);
} else {
  pages.push(1);
  if (currentPage > 3) pages.push('...');
  const start = Math.max(2, currentPage - 1);
  const end = Math.min(totalPages - 1, currentPage + 1);
  for (let i = start; i <= end; i++) pages.push(i);
  if (currentPage < totalPages - 2) pages.push('...');
  pages.push(totalPages);
}
---

{totalPages > 1 && (
  <section id="pagination-2" class="pagination-2 section">
    <div class="container">
      <div class="d-flex justify-content-center">
        <ul>
          <li>
            {currentPage > 1 ? (
              <a href={buildHref(currentPage - 1)}><i class="bi bi-chevron-left"></i></a>
            ) : (
              <span class="disabled"><i class="bi bi-chevron-left"></i></span>
            )}
          </li>
          {pages.map((p) =>
            p === '...' ? (
              <li>...</li>
            ) : (
              <li><a href={buildHref(p)} class={p === currentPage ? 'active' : ''}>{p}</a></li>
            )
          )}
          <li>
            {currentPage < totalPages ? (
              <a href={buildHref(currentPage + 1)}><i class="bi bi-chevron-right"></i></a>
            ) : (
              <span class="disabled"><i class="bi bi-chevron-right"></i></span>
            )}
          </li>
        </ul>
      </div>
    </div>
  </section>
)}
