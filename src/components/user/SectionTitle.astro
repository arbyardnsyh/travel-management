---
export interface Props {
  eyebrow: string;
  heading: string;
  description: string;
}

const { eyebrow, heading, description } = Astro.props;
---

<div class="container section-title">
  <h2>{heading}</h2>
  <div><span>{eyebrow}</span> <span class="description-title">{description}</span></div>
</div>
