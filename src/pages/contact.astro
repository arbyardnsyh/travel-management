---
import PublicLayout from '@/layouts/PublicLayout.astro';
import Breadcrumb from '@/components/user/Breadcrumb.astro';
import { getSettings } from '@/services';

const supabase = Astro.locals.supabase;
const settings = await getSettings(supabase);
---

<PublicLayout title="Contact" description="Hubungi tim kami untuk pertanyaan seputar perjalanan Anda.">
  <Breadcrumb title="Contact" current="Contact" subtitle="Kami siap membantu merencanakan perjalanan terbaik Anda." />

  <section id="contact" class="contact section">
    <div class="container">
      <div class="contact-wrapper">
        <div class="contact-info-panel">
          <div class="contact-info-header">
            <h3>Contact Information</h3>
            <p>Hubungi kami melalui salah satu kanal berikut, tim kami akan segera merespons.</p>
          </div>

          <div class="contact-info-cards">
            <div class="info-card">
              <div class="icon-container"><i class="bi bi-pin-map-fill"></i></div>
              <div class="card-content">
                <h4>Our Location</h4>
                <p>{settings?.address || '-'}</p>
              </div>
            </div>

            <div class="info-card">
              <div class="icon-container"><i class="bi bi-envelope-open"></i></div>
              <div class="card-content">
                <h4>Email Us</h4>
                <p>{settings?.email || '-'}</p>
              </div>
            </div>

            <div class="info-card">
              <div class="icon-container"><i class="bi bi-telephone-fill"></i></div>
              <div class="card-content">
                <h4>Call Us</h4>
                <p>{settings?.phone || '-'}</p>
              </div>
            </div>

            <div class="info-card">
              <div class="icon-container"><i class="bi bi-whatsapp"></i></div>
              <div class="card-content">
                <h4>WhatsApp</h4>
                <p>{settings?.whatsapp || '-'}</p>
              </div>
            </div>
          </div>

          <div class="social-links-panel">
            <h5>Follow Us</h5>
            <div class="social-icons">
              {settings?.facebook && <a href={settings.facebook} target="_blank" rel="noopener"><i class="bi bi-facebook"></i></a>}
              {settings?.instagram && <a href={settings.instagram} target="_blank" rel="noopener"><i class="bi bi-instagram"></i></a>}
              {settings?.youtube && <a href={settings.youtube} target="_blank" rel="noopener"><i class="bi bi-youtube"></i></a>}
            </div>
          </div>
        </div>

        <div class="contact-form-panel">
          <div class="form-container">
            <h3>Send Us a Message</h3>
            <p>Isi formulir di bawah ini, tim kami akan segera menghubungi Anda kembali.</p>

            <form id="contact-form-el" class="php-email-form" data-ajax-handled action="/api/public/contact" method="post">
              <div class="form-floating mb-3">
                <input type="text" class="form-control" id="c-name" name="name" placeholder="Full Name" required />
                <label for="c-name">Full Name</label>
              </div>

              <div class="form-floating mb-3">
                <input type="email" class="form-control" id="c-email" name="email" placeholder="Email Address" required />
                <label for="c-email">Email Address</label>
              </div>

              <div class="form-floating mb-3">
                <input type="text" class="form-control" id="c-subject" name="subject" placeholder="Subject" />
                <label for="c-subject">Subject</label>
              </div>

              <div class="form-floating mb-3">
                <textarea class="form-control" id="c-message" name="message" rows="5" placeholder="Your Message" style="height: 150px" required></textarea>
                <label for="c-message">Your Message</label>
              </div>

              <div class="my-3">
                <div class="loading">Loading</div>
                <div class="error-message"></div>
                <div class="sent-message">Pesan Anda berhasil terkirim. Terima kasih!</div>
              </div>

              <div class="d-grid">
                <button type="submit" class="btn-submit">Send Message <i class="bi bi-send-fill ms-2"></i></button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form-el') as HTMLFormElement | null;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      // BUG FIX (Contact double-submit / false "Error: {success:true}"):
      // root cause was the vendor script `validate.js` binding its own
      // submit listener to every `.php-email-form` on the page (it expects
      // the raw response body to literally be "OK"). The form now carries
      // `data-ajax-handled`, which validate.js skips — see that file for
      // details. No `stopImmediatePropagation()` needed here since the
      // vendor listener is never attached to this form in the first place.
      const loading = form.querySelector<HTMLElement>('.loading');
      const errorMessage = form.querySelector<HTMLElement>('.error-message');
      const sentMessage = form.querySelector<HTMLElement>('.sent-message');
      [loading, errorMessage, sentMessage].forEach((el) => el && (el.style.display = 'none'));
      if (loading) loading.style.display = 'block';

      try {
        const res = await fetch('/api/public/contact', { method: 'POST', body: new FormData(form) });
        const json = await res.json();
        if (loading) loading.style.display = 'none';
        if (!res.ok || !json.success) {
          if (errorMessage) {
            errorMessage.textContent = 'Terjadi kesalahan. Periksa kembali data Anda.';
            errorMessage.style.display = 'block';
          }
          return;
        }
        if (sentMessage) sentMessage.style.display = 'block';
        form.reset();
      } catch {
        if (loading) loading.style.display = 'none';
        if (errorMessage) {
          errorMessage.textContent = 'Gagal terhubung ke server. Coba lagi.';
          errorMessage.style.display = 'block';
        }
      }
    });
  </script>
</PublicLayout>
