---
import PublicLayout from '@/layouts/PublicLayout.astro';
import Breadcrumb from '@/components/user/Breadcrumb.astro';
import Pagination from '@/components/user/Pagination.astro';
import { listGallery } from '@/services';
import { publicStorageUrl } from '@/utils/storage';

const supabase = Astro.locals.supabase;
const url = Astro.url;
const page = Math.max(1, Number(url.searchParams.get('page') ?? 1) || 1);
const category = url.searchParams.get('category') ?? '';

const { data: items, totalPages } = await listGallery(supabase, {
  category: category || undefined,
  page,
  perPage: 12,
});

const { data: allItems } = await listGallery(supabase, { perPage: 100 });
const categories = Array.from(new Set(allItems.map((g) => g.category).filter((c): c is string => !!c)));
const slider = allItems.slice(0, 8);
---

<PublicLayout title="Gallery" description="Koleksi foto perjalanan dan destinasi terbaik kami.">
  <Breadcrumb title="Gallery" current="Gallery" subtitle="Momen-momen terbaik dari setiap perjalanan bersama kami." />

  {slider.length > 0 && (
    <section id="gallery-slider" class="gallery-slider section">
      <div class="container">
        <div class="gallery-container">
          <div class="swiper init-swiper">
            <script type="application/json" class="swiper-config" set:html={JSON.stringify({
              loop: true,
              speed: 800,
              autoplay: { delay: 4000 },
              effect: 'coverflow',
              grabCursor: true,
              centeredSlides: true,
              slidesPerView: 'auto',
              coverflowEffect: { rotate: 50, stretch: 0, depth: 100, modifier: 1, slideShadows: true },
              pagination: { el: '.swiper-pagination', type: 'bullets', clickable: true },
              navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
              breakpoints: {
                '320': { slidesPerView: 1, spaceBetween: 10 },
                '768': { slidesPerView: 2, spaceBetween: 20 },
                '1024': { slidesPerView: 3, spaceBetween: 30 },
              },
            })} />
            <div class="swiper-wrapper">
              {slider.map((g) => (
                <div class="swiper-slide">
                  <div class="gallery-item">
                    <div class="gallery-img">
                      <a class="glightbox" data-gallery="images-gallery" href={publicStorageUrl(supabase, g.image_url)}>
                        <img src={publicStorageUrl(supabase, g.image_url)} class="img-fluid" alt={g.title} loading="lazy" />
                        <div class="gallery-overlay"><i class="bi bi-plus-circle"></i></div>
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="swiper-pagination"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-button-next"></div>
          </div>
        </div>
      </div>
    </section>
  )}

  <section id="gallery" class="gallery section">
    <div class="container">
      {categories.length > 0 && (
        <div class="filter-tabs">
          <ul class="gallery-filters">
            <li class={!category ? 'active' : ''}>
              <a href="/gallery">All</a>
            </li>
            {categories.map((c) => (
              <li class={category === c ? 'active' : ''}>
                <a href={`/gallery?category=${encodeURIComponent(c)}`}>{c}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="gallery-grid">
        {items.length === 0 && (
          <p class="text-center text-muted py-5">Belum ada foto galeri.</p>
        )}
        {items.map((g, i) => (
          <div class={`gallery-card ${i % 7 === 1 || i % 7 === 6 ? 'featured' : ''}`}>
            <a class="glightbox" data-gallery="images-gallery" href={publicStorageUrl(supabase, g.image_url)}>
              <div class="gallery-card-image">
                <img src={publicStorageUrl(supabase, g.image_url)} class="img-fluid" alt={g.title} loading="lazy" />
                <div class="gallery-card-overlay">
                  <i class="bi bi-eye-fill"></i>
                  <span>View</span>
                </div>
              </div>
              {g.title && <div class="gallery-card-caption">{g.title}</div>}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Pagination currentPage={page} totalPages={totalPages} basePath="/gallery" searchParams={url.searchParams} />
</PublicLayout>

<style>
  /* Perbaikan UI Gallery */
  .gallery-slider {
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    padding-bottom: 3rem;
  }
  .swiper {
    padding: 2rem 0 3rem;
  }
  .swiper-slide .gallery-item .gallery-img {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    transition: transform 0.3s ease;
  }
  .swiper-slide .gallery-item .gallery-img:hover {
    transform: scale(1.02);
  }
  .swiper-slide .gallery-item .gallery-img img {
    width: 100%;
    height: 350px;
    object-fit: cover;
  }
  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
    font-size: 2.5rem;
    color: white;
  }
  .gallery-img:hover .gallery-overlay {
    opacity: 1;
  }

  /* Filter tabs yang lebih modern */
  .filter-tabs {
    display: flex;
    justify-content: center;
    margin-bottom: 3rem;
  }
  .gallery-filters {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .gallery-filters li a {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: white;
    border-radius: 30px;
    color: #334155;
    font-weight: 500;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
    border: 1px solid #e2e8f0;
  }
  .gallery-filters li.active a,
  .gallery-filters li a:hover {
    background: #2563eb;
    color: white;
    border-color: #2563eb;
    box-shadow: 0 8px 20px rgba(37,99,235,0.3);
  }

  /* Grid galeri baru */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .gallery-card {
    border-radius: 20px;
    overflow: hidden;
    background: white;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .gallery-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.12);
  }
  .gallery-card.featured {
    grid-column: span 2;
    grid-row: span 2;
  }
  .gallery-card-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .gallery-card.featured .gallery-card-image {
    aspect-ratio: auto;
    height: 100%;
  }
  .gallery-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    display: block;
  }
  .gallery-card:hover .gallery-card-image img {
    transform: scale(1.1);
  }
  .gallery-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 60%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    opacity: 0;
    transition: opacity 0.3s;
    color: white;
    font-size: 1.2rem;
  }
  .gallery-card:hover .gallery-card-overlay {
    opacity: 1;
  }
  .gallery-card-overlay i {
    font-size: 2.2rem;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }
  .gallery-card-caption {
    padding: 0.8rem 1rem;
    font-weight: 500;
    color: #1e293b;
    text-align: center;
    background: #f8fafc;
    border-top: 1px solid #e2e8f0;
    font-size: 0.95rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .gallery-card.featured {
      grid-column: span 1;
      grid-row: span 1;
    }
    .gallery-grid {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    }
    .swiper-slide .gallery-item .gallery-img img {
      height: 250px;
    }
  }
</style>