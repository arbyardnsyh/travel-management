---
// Batch 3A-8 — Profile page (self-service). Adapts PowerAdmin's
// profile.html tab layout (Overview / Edit Profile / Password) to the
// fields our schema actually has (name, email [read-only], avatar, role,
// joined date) — no new columns invented for fields the template shows
// (phone/company/address/etc) that don't exist in `public.users`.
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import FormField from '@/components/admin/FormField.astro';
import ImageUploader from '@/components/admin/ImageUploader.astro';
import StatusBadge from '@/components/admin/StatusBadge.astro';
import { listActivityLogs } from '@/services';
import { formatDate, publicStorageUrl } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const user = Astro.locals.user!; // /admin/** is already auth-gated by middleware

const logs = await listActivityLogs(supabase, { actorId: user.id, perPage: 15 });
const roleLabel = user.role.charAt(0).toUpperCase() + user.role.slice(1);
const avatarSrc = user.avatar_url ? publicStorageUrl(supabase, user.avatar_url) : '/assets-admin/img/profile-img.webp';

const searchParams = Astro.url.searchParams;
const toast = searchParams.get('toast');
const toastType = searchParams.get('toastType') ?? 'success';
const fieldError = (name: string) => searchParams.get(`error_${name}`) ?? null;
const activeTab = searchParams.get('tab') ?? 'overview';
---

<AdminLayout title="Profile">
  <div class="page-profile">
    <PageHeader title="Profile" crumbs={[{ label: 'Profile' }]} />

    {toast && (
      <div class={`alert alert-${toastType === 'success' ? 'success' : 'danger'} d-flex align-items-center gap-2`}>
        <i class={`bi ${toastType === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle'}`}></i>
        {toast}
      </div>
    )}

    <div class="card profile-hero-card">
      <div class="card-body">
        <div class="profile-hero-body">
          <div class="profile-hero-avatar-wrap">
            <img src={avatarSrc} alt={user.name} class="profile-hero-avatar" />
          </div>
          <div class="profile-hero-info">
            <div class="profile-hero-name">{user.name}</div>
            <div class="profile-hero-role">{roleLabel} &middot; {user.email}</div>
            <div class="profile-hero-location">
              <i class="bi bi-calendar3 me-1"></i> Bergabung {formatDate(user.created_at)}
            </div>
          </div>
          <div class="profile-hero-actions">
            <StatusBadge status={user.is_active ? 'active' : 'inactive'} label={user.is_active ? 'Aktif' : 'Nonaktif'} />
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <ul class="profile-tabs" role="tablist">
              <li role="presentation">
                <button class={`profile-tab ${activeTab === 'overview' ? 'active' : ''}`} data-bs-toggle="tab" data-bs-target="#tab-overview" type="button" role="tab">Overview</button>
              </li>
              <li role="presentation">
                <button class={`profile-tab ${activeTab === 'edit' ? 'active' : ''}`} data-bs-toggle="tab" data-bs-target="#tab-edit" type="button" role="tab">Edit Profile</button>
              </li>
              <li role="presentation">
                <button class={`profile-tab ${activeTab === 'password' ? 'active' : ''}`} data-bs-toggle="tab" data-bs-target="#tab-password" type="button" role="tab">Password</button>
              </li>
              <li role="presentation">
                <button class={`profile-tab ${activeTab === 'activity' ? 'active' : ''}`} data-bs-toggle="tab" data-bs-target="#tab-activity" type="button" role="tab">Riwayat Aktivitas</button>
              </li>
            </ul>

            <div class="tab-content">
              <!-- Overview -->
              <div class={`tab-pane fade ${activeTab === 'overview' ? 'show active' : ''}`} id="tab-overview" role="tabpanel">
                <div class="profile-section-label">Informasi Akun</div>
                <div class="profile-detail-grid">
                  <div class="profile-detail-row">
                    <span class="profile-detail-key">Nama Lengkap</span>
                    <span class="profile-detail-val">{user.name}</span>
                  </div>
                  <div class="profile-detail-row">
                    <span class="profile-detail-key">Email</span>
                    <span class="profile-detail-val">{user.email}</span>
                  </div>
                  <div class="profile-detail-row">
                    <span class="profile-detail-key">Role</span>
                    <span class="profile-detail-val">{roleLabel}</span>
                  </div>
                  <div class="profile-detail-row">
                    <span class="profile-detail-key">Status</span>
                    <span class="profile-detail-val">{user.is_active ? 'Aktif' : 'Nonaktif'}</span>
                  </div>
                  <div class="profile-detail-row">
                    <span class="profile-detail-key">Bergabung</span>
                    <span class="profile-detail-val">{formatDate(user.created_at, true)}</span>
                  </div>
                </div>
              </div>

              <!-- Edit Profile -->
              <div class={`tab-pane fade ${activeTab === 'edit' ? 'show active' : ''}`} id="tab-edit" role="tabpanel">
                <form method="post" action="/api/admin/profile" id="profileEditForm">
                  <input type="hidden" name="_method" value="PUT" />
                  <ImageUploader name="avatar_url" label="Foto Profil" folder="avatar" value={user.avatar_url} help="JPG, PNG, atau WEBP, maks 5MB." />
                  <FormField label="Nama Lengkap" name="name" value={user.name} required error={fieldError('name')} />
                  <FormField label="Email" name="email_display" value={user.email} disabled readonly help="Email tidak dapat diubah dari sini." />
                  <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary" data-submit-btn>
                      <i class="bi bi-check-lg me-1"></i> Simpan Perubahan
                    </button>
                  </div>
                </form>
              </div>

              <!-- Change Password -->
              <div class={`tab-pane fade ${activeTab === 'password' ? 'show active' : ''}`} id="tab-password" role="tabpanel">
                <form method="post" action="/api/admin/profile/password" id="passwordForm">
                  <div class="row">
                    <div class="col-md-12 mb-3">
                      <FormField label="Password Saat Ini" name="current_password" type="password" placeholder="Masukkan password saat ini" required error={fieldError('current_password')} />
                    </div>
                    <div class="col-md-6 mb-3">
                      <FormField label="Password Baru" name="new_password" type="password" placeholder="Minimal 8 karakter" required error={fieldError('new_password')} />
                    </div>
                    <div class="col-md-6 mb-3">
                      <FormField label="Konfirmasi Password Baru" name="confirm_password" type="password" placeholder="Ulangi password baru" required error={fieldError('confirm_password')} />
                    </div>
                  </div>
                  <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary" data-submit-btn>
                      <i class="bi bi-check-lg me-1"></i> Ubah Password
                    </button>
                  </div>
                </form>
              </div>

              <!-- Personal Activity Log -->
              <div class={`tab-pane fade ${activeTab === 'activity' ? 'show active' : ''}`} id="tab-activity" role="tabpanel">
                {logs.data.length === 0 ? (
                  <p class="text-muted small mb-0">Belum ada aktivitas tercatat.</p>
                ) : (
                  <ul class="list-group list-group-flush">
                    {logs.data.map((log) => (
                      <li class="list-group-item d-flex justify-content-between align-items-start px-0">
                        <div>
                          <div class="fw-medium">{log.description ?? log.action}</div>
                          <div class="text-muted small">{log.entity}{log.entity_id ? ` #${log.entity_id.slice(0, 8)}` : ''}</div>
                        </div>
                        <span class="text-muted small">{formatDate(log.created_at, true)}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  ['profileEditForm', 'passwordForm'].forEach((formId) => {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    form?.addEventListener('submit', () => {
      const btn = form.querySelector('[data-submit-btn]') as HTMLButtonElement | null;
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Menyimpan...';
      }
    });
  });
</script>
