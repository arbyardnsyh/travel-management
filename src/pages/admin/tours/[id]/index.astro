---
// Batch 3A-2 — Tour detail (read-only view). New page, following the same
// folder/URL convention as [id]/edit.astro — no change to existing routes.
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import StatusBadge from '@/components/admin/StatusBadge.astro';
import ConfirmDeleteModal from '@/components/shared/ConfirmDeleteModal.astro';
import { getTourById, listActivityLogs } from '@/services';
import { publicStorageUrl, formatCurrency, formatDate } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const { id } = Astro.params;

const tour = id ? await getTourById(supabase, id) : null;
if (!tour) {
  return Astro.redirect('/admin/tours?toast=' + encodeURIComponent('Tour tidak ditemukan.') + '&toastType=error');
}

const logs = await listActivityLogs(supabase, { entity: 'tours', entityId: tour.id, perPage: 10 });
const thumbnailUrl = tour.thumbnail ? publicStorageUrl(supabase, tour.thumbnail) : '';
---

<AdminLayout title={`Detail ${tour.title}`}>
  <PageHeader title="Detail Tour" crumbs={[{ label: 'Master Data' }, { label: 'Tours', href: '/admin/tours' }, { label: tour.title }]}>
    <a href={`/admin/tours/${tour.id}/edit`} class="btn btn-primary me-2">
      <i class="bi bi-pencil me-1"></i> Edit
    </a>
    <a href="/admin/tours" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Kembali
    </a>
  </PageHeader>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title mb-0">{tour.title}</h5>
          <StatusBadge status={tour.status} />
        </div>
        <div class="card-body">
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Slug</div>
            <div class="col-md-8">{tour.slug}</div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Destinasi</div>
            <div class="col-md-8">
              {tour.destination ? (
                <a href={`/admin/destinations/${tour.destination.id}/edit`}>{tour.destination.name}</a>
              ) : (
                <span class="text-muted">Tidak ada relasi destinasi</span>
              )}
            </div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Harga</div>
            <div class="col-md-8">{formatCurrency(tour.price)}</div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Durasi</div>
            <div class="col-md-8">{tour.duration || <span class="text-muted">—</span>}</div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Kuota</div>
            <div class="col-md-8">{tour.quota}</div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Dibuat</div>
            <div class="col-md-8">{formatDate(tour.created_at, true)}</div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Diperbarui</div>
            <div class="col-md-8">{formatDate(tour.updated_at, true)}</div>
          </div>
          <hr />
          <div class="row">
            <div class="col-md-4 text-muted small">Deskripsi</div>
            <div class="col-md-8">
              {tour.description ? (
                <p class="mb-0" style="white-space: pre-line;">{tour.description}</p>
              ) : (
                <span class="text-muted">Belum ada deskripsi.</span>
              )}
            </div>
          </div>
        </div>
      </div>

      <div class="card mt-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Riwayat Aktivitas</h5>
        </div>
        <div class="card-body p-0">
          {logs.data.length === 0 ? (
            <p class="text-muted small p-3 mb-0">Belum ada aktivitas tercatat.</p>
          ) : (
            <ul class="list-group list-group-flush">
              {logs.data.map((log) => (
                <li class="list-group-item d-flex justify-content-between align-items-start">
                  <div>
                    <div class="fw-medium">{log.description ?? log.action}</div>
                    <div class="text-muted small">{log.actor_name ?? 'Sistem'}</div>
                  </div>
                  <span class="text-muted small">{formatDate(log.created_at, true)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Thumbnail</h5>
        </div>
        <div class="card-body">
          {thumbnailUrl ? (
            <img src={thumbnailUrl} alt={tour.title} class="img-fluid rounded-3" style="width:100%;object-fit:cover;" />
          ) : (
            <div class="rounded-3 bg-secondary-subtle d-flex align-items-center justify-content-center" style="width:100%;height:180px;">
              <i class="bi bi-image text-secondary fs-1"></i>
            </div>
          )}
        </div>
      </div>

      <div class="card">
        <div class="card-body d-grid gap-2">
          <a href={`/admin/tours/${tour.id}/edit`} class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i> Edit Tour
          </a>
          <button
            type="button"
            class="btn btn-outline-danger"
            onclick={`openDeleteModal({ action: '/api/admin/tours/${tour.id}', label: '${tour.title.replace(/'/g, "\\'")}' })`}
          >
            <i class="bi bi-trash3 me-1"></i> Hapus Tour
          </button>
        </div>
      </div>
    </div>
  </div>

  <ConfirmDeleteModal />
</AdminLayout>
