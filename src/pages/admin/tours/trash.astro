---
// Batch 3A-2 — Tours trash (mirrors /admin/destinations/trash.astro pattern).
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import DataTable from '@/components/admin/DataTable.astro';
import EmptyState from '@/components/admin/EmptyState.astro';
import ConfirmDeleteModal from '@/components/shared/ConfirmDeleteModal.astro';
import { listTours } from '@/services';
import { formatDate, publicStorageUrl } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const user = Astro.locals.user;
const searchParams = Astro.url.searchParams;

const q = searchParams.get('q') ?? '';
const page = Math.max(1, Number(searchParams.get('page') ?? 1) || 1);
const perPage = 10;

const { data: tours, count, totalPages } = await listTours(supabase, {
  q: q || undefined,
  onlyDeleted: true,
  page,
  perPage,
});

const toast = searchParams.get('toast');
const toastType = searchParams.get('toastType') ?? 'success';
---

<AdminLayout title="Arsip Tours">
  <PageHeader title="Arsip Tours" crumbs={[{ label: 'Master Data' }, { label: 'Tours', href: '/admin/tours' }, { label: 'Arsip' }]}>
    <a href="/admin/tours" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Kembali
    </a>
  </PageHeader>

  {toast && (
    <div class={`alert alert-${toastType === 'success' ? 'success' : 'danger'} d-flex align-items-center gap-2`}>
      <i class={`bi ${toastType === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle'}`}></i>
      {toast}
    </div>
  )}

  {tours.length === 0 && !q ? (
    <div class="card">
      <div class="card-body">
        <EmptyState icon="bi bi-trash3" title="Arsip kosong" text="Tour yang dihapus akan muncul di sini dan dapat dipulihkan kapan saja." />
      </div>
    </div>
  ) : (
    <DataTable
      columns={[
        { key: 'title', label: 'Tour' },
        { key: 'destination', label: 'Destinasi' },
        { key: 'deleted_at', label: 'Diarsipkan' },
      ]}
      basePath="/admin/tours/trash"
      searchParams={searchParams}
      searchPlaceholder="Cari tour diarsipkan..."
      page={page}
      totalPages={totalPages}
      total={count}
      perPage={perPage}
      itemLabel="tour"
      isEmpty={tours.length === 0}
      emptyIcon="bi bi-search"
      emptyTitle="Tidak ditemukan"
      emptyText={`Tidak ada tour diarsipkan yang cocok dengan "${q}".`}
      actionsLabel="Aksi"
    >
      {tours.map((tour) => (
        <tr>
          <td>
            <div class="d-flex align-items-center gap-2">
              {tour.thumbnail ? (
                <img
                  src={publicStorageUrl(supabase, tour.thumbnail)}
                  alt={tour.title}
                  width="40"
                  height="40"
                  class="rounded-2"
                  style="object-fit:cover;"
                />
              ) : (
                <div class="rounded-2 bg-secondary-subtle d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                  <i class="bi bi-image text-secondary"></i>
                </div>
              )}
              <div class="fw-semibold text-muted">{tour.title}</div>
            </div>
          </td>
          <td>{tour.destination?.name ?? <span class="text-muted">—</span>}</td>
          <td class="users-meta">{formatDate(tour.deleted_at)}</td>
          <td class="text-center">
            <div class="users-actions">
              <form method="post" action={`/api/admin/tours/${tour.id}/restore`} class="d-inline">
                <button type="submit" class="users-action-btn" title="Pulihkan">
                  <i class="bi bi-arrow-counterclockwise"></i>
                </button>
              </form>
              {user?.role === 'admin' && (
                <button
                  type="button"
                  class="users-action-btn danger"
                  title="Hapus Permanen"
                  onclick={`openDeleteModal({ action: '/api/admin/tours/${tour.id}?permanent=1', label: '${tour.title.replace(/'/g, "\\'")} (permanen)' })`}
                >
                  <i class="bi bi-trash3-fill"></i>
                </button>
              )}
            </div>
          </td>
        </tr>
      ))}
    </DataTable>
  )}

  <ConfirmDeleteModal />
</AdminLayout>
