---
// Batch 3A-11 — Contact message detail (read-only view + mark read/unread +
// delete + activity log). Mirrors /admin/testimonials/[id]/index.astro.
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import StatusBadge from '@/components/admin/StatusBadge.astro';
import ConfirmDeleteModal from '@/components/shared/ConfirmDeleteModal.astro';
import { getContactById, listActivityLogs, markContactRead } from '@/services';
import { formatDate } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const user = Astro.locals.user;
const { id } = Astro.params;

const contact = id ? await getContactById(supabase, id) : null;
if (!contact) {
  return Astro.redirect('/admin/contacts?toast=' + encodeURIComponent('Pesan tidak ditemukan.') + '&toastType=error');
}

// Viewing the detail page implicitly marks the message as read, same
// convenience behavior as a typical inbox — still leaves the explicit
// "Tandai Belum Dibaca" action available below for the admin to revert.
if (!contact.is_read) {
  await markContactRead(supabase, contact.id, user);
  contact.is_read = true;
}

const logs = await listActivityLogs(supabase, { entity: 'contacts', entityId: contact.id, perPage: 10 });
---

<AdminLayout title="Detail Pesan Kontak">
  <PageHeader title="Detail Pesan Kontak" crumbs={[{ label: 'Interaction' }, { label: 'Contact Messages', href: '/admin/contacts' }, { label: contact.name }]}>
    <a href="/admin/contacts" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Kembali
    </a>
  </PageHeader>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title mb-0">{contact.subject || 'Tanpa Subject'}</h5>
          <StatusBadge status={contact.is_read ? 'read' : 'unread'} label={contact.is_read ? 'Read' : 'Unread'} />
        </div>
        <div class="card-body">
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Nama</div>
            <div class="col-md-8">{contact.name}</div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Email</div>
            <div class="col-md-8"><a href={`mailto:${contact.email}`}>{contact.email}</a></div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Subject</div>
            <div class="col-md-8">{contact.subject || <span class="text-muted">Tidak ada subject</span>}</div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Pesan</div>
            <div class="col-md-8" style="white-space:pre-wrap;">{contact.message}</div>
          </div>
          <div class="row">
            <div class="col-md-4 text-muted small">Dikirim</div>
            <div class="col-md-8">{formatDate(contact.created_at, true)}</div>
          </div>
        </div>
      </div>

      <div class="card mt-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Riwayat Aktivitas</h5>
        </div>
        <div class="card-body p-0">
          {logs.data.length === 0 ? (
            <p class="text-muted small p-3 mb-0">Belum ada aktivitas tercatat.</p>
          ) : (
            <ul class="list-group list-group-flush">
              {logs.data.map((log) => (
                <li class="list-group-item d-flex justify-content-between align-items-start">
                  <div>
                    <div class="fw-medium">{log.description ?? log.action}</div>
                    <div class="text-muted small">{log.actor_name ?? 'Sistem'}</div>
                  </div>
                  <span class="text-muted small">{formatDate(log.created_at, true)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card">
        <div class="card-body d-grid gap-2">
          {contact.is_read ? (
            <form method="post" action={`/api/admin/contacts/${contact.id}/status`}>
              <input type="hidden" name="status" value="unread" />
              <button type="submit" class="btn btn-outline-secondary w-100">
                <i class="bi bi-envelope me-1"></i> Tandai Belum Dibaca
              </button>
            </form>
          ) : (
            <form method="post" action={`/api/admin/contacts/${contact.id}/status`}>
              <input type="hidden" name="status" value="read" />
              <button type="submit" class="btn btn-success w-100">
                <i class="bi bi-envelope-open me-1"></i> Tandai Dibaca
              </button>
            </form>
          )}
          <a href={`mailto:${contact.email}`} class="btn btn-primary">
            <i class="bi bi-reply me-1"></i> Balas via Email
          </a>
          <button
            type="button"
            class="btn btn-outline-danger"
            onclick={`openDeleteModal({ action: '/api/admin/contacts/${contact.id}', label: '${contact.name.replace(/'/g, "\\'")}' })`}
          >
            <i class="bi bi-trash3 me-1"></i> Hapus Pesan
          </button>
        </div>
      </div>
    </div>
  </div>

  <ConfirmDeleteModal />
</AdminLayout>
