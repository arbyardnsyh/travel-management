---
// Batch 3A-10 — Activity Logs. A dedicated, staff-facing view over
// `activity_logs` (written automatically by every other service's
// create/update/delete/status-change function via
// `src/lib/activity-log.ts#logActivity()`). Read-only by design: the table's
// RLS policies (supabase/migrations/0005_activity_logs.sql) only grant
// staff INSERT + SELECT — there is intentionally no UPDATE/DELETE policy —
// so this page offers List/Search/Filter/Pagination/Detail only, with no
// Edit or Delete actions, per the master prompt.
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import DataTable from '@/components/admin/DataTable.astro';
import { listActivityLogs, listUsers } from '@/services';
import { formatDate } from '@/lib/helpers';
import { ACTIVITY_ACTIONS, ACTIVITY_ENTITIES } from '@/lib/constants';
import type { ActivityAction, ActivityEntity } from '@/lib/constants';

const supabase = Astro.locals.supabase;
const searchParams = Astro.url.searchParams;

const q = searchParams.get('q') ?? '';
const action = (searchParams.get('action') as ActivityAction | null) ?? undefined;
const entity = (searchParams.get('entity') as ActivityEntity | null) ?? undefined;
const actorId = searchParams.get('actor') ?? undefined;
const page = Math.max(1, Number(searchParams.get('page') ?? 1) || 1);
const perPage = 15;

const [{ data: logs, count, totalPages }, { data: users }] = await Promise.all([
  listActivityLogs(supabase, { q: q || undefined, action, entity, actorId, page, perPage }),
  // Filter dropdown source data — a generous perPage keeps this a single
  // query, same approach as the destination/tour filter dropdowns on
  // /admin/bookings.
  listUsers(supabase, { perPage: 200 }),
]);

const toast = searchParams.get('toast');
const toastType = searchParams.get('toastType') ?? 'success';

const actionLabel = (a: string) => a.charAt(0).toUpperCase() + a.slice(1).replace(/_/g, ' ');
const entityLabel = (e: string) => e.charAt(0).toUpperCase() + e.slice(1).replace(/_/g, ' ');

const ACTION_COLOR: Record<string, string> = {
  create: 'success',
  update: 'info',
  soft_delete: 'warning',
  restore: 'info',
  delete: 'danger',
  status_change: 'primary',
  login: 'success',
  logout: 'secondary',
  reset_password: 'warning',
  change_password: 'warning',
};

const selectedUser = users.find((u) => u.id === actorId);

function filterHref(next: Partial<{ action: string; entity: string; actor: string }>): string {
  const params = new URLSearchParams();
  if (q) params.set('q', q);
  const nextAction = 'action' in next ? next.action : action;
  const nextEntity = 'entity' in next ? next.entity : entity;
  const nextActor = 'actor' in next ? next.actor : actorId;
  if (nextAction) params.set('action', nextAction);
  if (nextEntity) params.set('entity', nextEntity);
  if (nextActor) params.set('actor', nextActor);
  return `/admin/activity-logs?${params.toString()}`;
}
---

<AdminLayout title="Activity Logs">
  <PageHeader title="Activity Logs" crumbs={[{ label: 'Activity Logs' }]} />

  {toast && (
    <div class={`alert alert-${toastType === 'success' ? 'success' : 'danger'} d-flex align-items-center gap-2`}>
      <i class={`bi ${toastType === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle'}`}></i>
      {toast}
    </div>
  )}

  <DataTable
    columns={[
      { key: 'created_at', label: 'Waktu' },
      { key: 'actor_name', label: 'Aktor' },
      { key: 'action', label: 'Aksi' },
      { key: 'entity', label: 'Entitas' },
      { key: 'description', label: 'Deskripsi' },
    ]}
    basePath="/admin/activity-logs"
    searchParams={searchParams}
    searchPlaceholder="Cari deskripsi aktivitas..."
    page={page}
    totalPages={totalPages}
    total={count}
    perPage={perPage}
    itemLabel="log aktivitas"
    isEmpty={logs.length === 0}
    emptyIcon="bi bi-clock-history"
    emptyTitle={q ? 'Log tidak ditemukan' : 'Belum ada aktivitas'}
    emptyText={q ? `Tidak ada log yang cocok dengan "${q}".` : 'Aktivitas admin (tambah/ubah/hapus data) akan tercatat di sini secara otomatis.'}
    actionsLabel="Detail"
  >
    <Fragment slot="filters">
      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
          <i class="bi bi-lightning-charge me-1"></i> {action ? actionLabel(action) : 'Semua Aksi'}
        </button>
        <ul class="dropdown-menu dropdown-menu-end" style="max-height:300px;overflow-y:auto;">
          <li><a class="dropdown-item" href={filterHref({ action: '' })}>Semua Aksi</a></li>
          {ACTIVITY_ACTIONS.map((a) => (
            <li><a class="dropdown-item" href={filterHref({ action: a })}>{actionLabel(a)}</a></li>
          ))}
        </ul>
      </div>

      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
          <i class="bi bi-box-seam me-1"></i> {entity ? entityLabel(entity) : 'Semua Entitas'}
        </button>
        <ul class="dropdown-menu dropdown-menu-end" style="max-height:300px;overflow-y:auto;">
          <li><a class="dropdown-item" href={filterHref({ entity: '' })}>Semua Entitas</a></li>
          {ACTIVITY_ENTITIES.map((e) => (
            <li><a class="dropdown-item" href={filterHref({ entity: e })}>{entityLabel(e)}</a></li>
          ))}
        </ul>
      </div>

      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
          <i class="bi bi-person me-1"></i> {selectedUser ? selectedUser.name : 'Semua Pengguna'}
        </button>
        <ul class="dropdown-menu dropdown-menu-end" style="max-height:300px;overflow-y:auto;">
          <li><a class="dropdown-item" href={filterHref({ actor: '' })}>Semua Pengguna</a></li>
          {users.map((u) => (
            <li><a class="dropdown-item" href={filterHref({ actor: u.id })}>{u.name}</a></li>
          ))}
        </ul>
      </div>
    </Fragment>

    {logs.map((log) => (
      <tr>
        <td class="users-meta">{formatDate(log.created_at, true)}</td>
        <td>{log.actor_name ?? <span class="text-muted">Sistem/Publik</span>}</td>
        <td>
          <span class={`badge bg-${ACTION_COLOR[log.action] ?? 'secondary'}-subtle text-${ACTION_COLOR[log.action] ?? 'secondary'}`}>
            {actionLabel(log.action)}
          </span>
        </td>
        <td>{entityLabel(log.entity)}</td>
        <td class="text-truncate" style="max-width: 320px;">{log.description ?? '-'}</td>
        <td class="text-center">
          <button
            type="button"
            class="users-action-btn"
            title="Detail"
            data-log-id={log.id}
            data-log-actor={log.actor_name ?? 'Sistem/Publik'}
            data-log-action={actionLabel(log.action)}
            data-log-entity={entityLabel(log.entity)}
            data-log-entity-id={log.entity_id ?? '-'}
            data-log-description={log.description ?? '-'}
            data-log-metadata={log.metadata ? JSON.stringify(log.metadata, null, 2) : '-'}
            data-log-created={formatDate(log.created_at, true)}
            data-log-open
          >
            <i class="bi bi-eye"></i>
          </button>
        </td>
      </tr>
    ))}
  </DataTable>

  <!-- Detail Modal (read-only — no Edit/Delete, per master prompt) -->
  <div class="modal fade" id="activityLogDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0">
          <h5 class="modal-title d-flex align-items-center gap-2">
            <i class="bi bi-clock-history"></i> Detail Aktivitas
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <dl class="row mb-0">
            <dt class="col-sm-3">Waktu</dt>
            <dd class="col-sm-9" data-detail-created>-</dd>

            <dt class="col-sm-3">Aktor</dt>
            <dd class="col-sm-9" data-detail-actor>-</dd>

            <dt class="col-sm-3">Aksi</dt>
            <dd class="col-sm-9" data-detail-action>-</dd>

            <dt class="col-sm-3">Entitas</dt>
            <dd class="col-sm-9" data-detail-entity>-</dd>

            <dt class="col-sm-3">ID Entitas</dt>
            <dd class="col-sm-9"><code data-detail-entity-id>-</code></dd>

            <dt class="col-sm-3">Deskripsi</dt>
            <dd class="col-sm-9" data-detail-description>-</dd>

            <dt class="col-sm-3">Metadata</dt>
            <dd class="col-sm-9">
              <pre class="bg-body-secondary p-2 rounded small mb-0" data-detail-metadata>-</pre>
            </dd>
          </dl>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Tutup</button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Read-only detail modal — populated from the triggering button's
  // `data-log-*` attributes (same lightweight pattern as
  // ConfirmDeleteModal.astro's `openDeleteModal()`). No fetch/edit/delete
  // wiring here by design.
  const modalEl = document.getElementById('activityLogDetailModal');

  function setText(selector: string, value: string) {
    const el = modalEl?.querySelector(selector);
    if (el) el.textContent = value;
  }

  document.querySelectorAll<HTMLButtonElement>('[data-log-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!modalEl) return;
      setText('[data-detail-created]', btn.dataset.logCreated ?? '-');
      setText('[data-detail-actor]', btn.dataset.logActor ?? '-');
      setText('[data-detail-action]', btn.dataset.logAction ?? '-');
      setText('[data-detail-entity]', btn.dataset.logEntity ?? '-');
      setText('[data-detail-entity-id]', btn.dataset.logEntityId ?? '-');
      setText('[data-detail-description]', btn.dataset.logDescription ?? '-');
      setText('[data-detail-metadata]', btn.dataset.logMetadata ?? '-');
      // @ts-ignore — bootstrap is loaded globally via AdminLayout's vendor script
      const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
      modal.show();
    });
  });
</script>
