---
// Batch 3A-6 — Blog Category detail. Mirrors /admin/faq/[id]/index.astro.
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import ConfirmDeleteModal from '@/components/shared/ConfirmDeleteModal.astro';
import { getBlogCategoryById, countBlogsInCategory, listActivityLogs } from '@/services';
import { formatDate } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const user = Astro.locals.user;
const { id } = Astro.params;

const category = id ? await getBlogCategoryById(supabase, id) : null;
if (!category) {
  return Astro.redirect('/admin/blogs/categories?toast=' + encodeURIComponent('Kategori tidak ditemukan.') + '&toastType=error');
}

const [blogCount, logs] = await Promise.all([
  countBlogsInCategory(supabase, category.id),
  listActivityLogs(supabase, { entity: 'blog_categories', entityId: category.id, perPage: 10 }),
]);
---

<AdminLayout title={`Detail Kategori — ${category.name}`}>
  <PageHeader title="Detail Kategori Blog" crumbs={[{ label: 'Blog' }, { label: 'Categories', href: '/admin/blogs/categories' }, { label: category.name }]}>
    <a href={`/admin/blogs/categories/${category.id}/edit`} class="btn btn-primary me-2">
      <i class="bi bi-pencil me-1"></i> Edit
    </a>
    <a href="/admin/blogs/categories" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Kembali
    </a>
  </PageHeader>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">{category.name}</h5>
        </div>
        <div class="card-body">
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Slug</div>
            <div class="col-md-8">{category.slug}</div>
          </div>
          <div class="row">
            <div class="col-md-4 text-muted small">Artikel Terkait</div>
            <div class="col-md-8">
              {blogCount} artikel aktif
              {blogCount > 0 && (
                <a href={`/admin/blogs?category=${category.id}`} class="ms-2 small">Lihat artikel &raquo;</a>
              )}
            </div>
          </div>
        </div>
      </div>

      <div class="card mt-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Riwayat Aktivitas</h5>
        </div>
        <div class="card-body p-0">
          {logs.data.length === 0 ? (
            <p class="text-muted small p-3 mb-0">Belum ada aktivitas tercatat.</p>
          ) : (
            <ul class="list-group list-group-flush">
              {logs.data.map((log) => (
                <li class="list-group-item d-flex justify-content-between align-items-start">
                  <div>
                    <div class="fw-medium">{log.description ?? log.action}</div>
                    <div class="text-muted small">{log.actor_name ?? 'Sistem'}</div>
                  </div>
                  <span class="text-muted small">{formatDate(log.created_at, true)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card">
        <div class="card-body d-grid gap-2">
          <a href={`/admin/blogs/categories/${category.id}/edit`} class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i> Edit Kategori
          </a>
          {user?.role === 'admin' && (
            <button
              type="button"
              class="btn btn-outline-danger"
              onclick={`openDeleteModal({ action: '/api/admin/blogs/categories/${category.id}', label: '${category.name.replace(/'/g, "\\'")}' })`}
            >
              <i class="bi bi-trash3 me-1"></i> Hapus Kategori
            </button>
          )}
        </div>
      </div>
    </div>
  </div>

  <ConfirmDeleteModal />
</AdminLayout>
