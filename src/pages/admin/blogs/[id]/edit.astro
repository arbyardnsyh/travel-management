---
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import FormField from '@/components/admin/FormField.astro';
import ImageUploader from '@/components/admin/ImageUploader.astro';
import RichTextEditor from '@/components/admin/RichTextEditor.astro';
import ConfirmDeleteModal from '@/components/shared/ConfirmDeleteModal.astro';
import { CONTENT_STATUSES } from '@/lib/constants';
import { getBlogById, listBlogCategories, listActivityLogs } from '@/services';
import { formatDate } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const { id } = Astro.params;

const blog = id ? await getBlogById(supabase, id) : null;
if (!blog) {
  return Astro.redirect('/admin/blogs?toast=' + encodeURIComponent('Artikel tidak ditemukan.') + '&toastType=error');
}

const [categories, logs] = await Promise.all([
  listBlogCategories(supabase),
  listActivityLogs(supabase, { entity: 'blogs', entityId: blog.id, perPage: 8 }),
]);

const searchParams = Astro.url.searchParams;
const toast = searchParams.get('toast');
const toastType = searchParams.get('toastType') ?? 'error';
const fieldError = (name: string) => searchParams.get(`error_${name}`) ?? null;

const statusOptions = CONTENT_STATUSES.map((s) => ({ value: s, label: s.charAt(0).toUpperCase() + s.slice(1) }));
const categoryOptions = [{ value: '', label: '— Tanpa Kategori —' }, ...categories.map((c) => ({ value: c.id, label: c.name }))];

// <input type="datetime-local"> needs "YYYY-MM-DDTHH:mm", not a full ISO timestamp.
const publishedAtLocal = blog.published_at ? blog.published_at.slice(0, 16) : '';
---

<AdminLayout title={`Edit ${blog.title}`}>
  <PageHeader title="Edit Artikel Blog" crumbs={[{ label: 'Blog' }, { label: 'Articles', href: '/admin/blogs' }, { label: blog.title }]}>
    <a href={`/admin/blogs/${blog.id}/preview`} class="btn btn-outline-secondary me-2" target="_blank">
      <i class="bi bi-box-arrow-up-right me-1"></i> Preview
    </a>
    <a href="/admin/blogs" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Kembali
    </a>
  </PageHeader>

  {toast && (
    <div class={`alert alert-${toastType === 'success' ? 'success' : 'danger'} d-flex align-items-center gap-2`}>
      <i class={`bi ${toastType === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle'}`}></i>
      {toast}
    </div>
  )}

  <form method="post" action={`/api/admin/blogs/${blog.id}`} id="blogForm">
    <input type="hidden" name="_method" value="PUT" />
    <div class="row g-4">
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title mb-0">Informasi Artikel</h5>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-8">
                <FormField label="Judul Artikel" name="title" value={blog.title} required error={fieldError('title')} />
              </div>
              <div class="col-md-4">
                <FormField label="Slug" name="slug" value={blog.slug} help="Kosongkan untuk mempertahankan slug saat ini." error={fieldError('slug')} />
              </div>
            </div>
            <div class="row">
              <div class="col-md-6">
                <FormField label="Kategori" name="category_id" as="select" options={categoryOptions} value={blog.category_id ?? ''} error={fieldError('category_id')} />
              </div>
              <div class="col-md-6">
                <FormField label="Penulis" name="author" value={blog.author ?? ''} placeholder="Nama penulis" error={fieldError('author')} />
              </div>
            </div>
            <RichTextEditor name="content" label="Konten" value={blog.content} error={fieldError('content')} />
          </div>
        </div>

        <div class="card mt-4">
          <div class="card-header">
            <h5 class="card-title mb-0">Riwayat Aktivitas</h5>
          </div>
          <div class="card-body p-0">
            {logs.data.length === 0 ? (
              <p class="text-muted small p-3 mb-0">Belum ada aktivitas tercatat.</p>
            ) : (
              <ul class="list-group list-group-flush">
                {logs.data.map((log) => (
                  <li class="list-group-item d-flex justify-content-between align-items-start">
                    <div>
                      <div class="fw-medium">{log.description ?? log.action}</div>
                      <div class="text-muted small">{log.actor_name ?? 'Sistem'}</div>
                    </div>
                    <span class="text-muted small">{formatDate(log.created_at, true)}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card mb-4">
          <div class="card-header">
            <h5 class="card-title mb-0">Publikasi</h5>
          </div>
          <div class="card-body">
            <FormField label="Status" name="status" as="select" options={statusOptions} value={blog.status} error={fieldError('status')} />
            <FormField
              label="Tanggal Terbit (opsional)"
              name="published_at"
              type="datetime-local"
              value={publishedAtLocal}
              help="Kosongkan jika belum dijadwalkan."
              error={fieldError('published_at')}
            />
          </div>
        </div>

        <div class="card mb-4">
          <div class="card-header">
            <h5 class="card-title mb-0">Thumbnail</h5>
          </div>
          <div class="card-body">
            <ImageUploader name="thumbnail" label="Thumbnail" folder="blog" value={blog.thumbnail} error={fieldError('thumbnail')} />
          </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-2" data-submit-btn>
          <i class="bi bi-check-lg me-1"></i> Simpan Perubahan
        </button>
        <button
          type="button"
          class="btn btn-outline-danger w-100"
          onclick={`openDeleteModal({ action: '/api/admin/blogs/${blog.id}', label: '${blog.title.replace(/'/g, "\\'")}' })`}
        >
          <i class="bi bi-trash3 me-1"></i> Hapus Artikel
        </button>
      </div>
    </div>
  </form>

  <ConfirmDeleteModal />
</AdminLayout>

<script>
  const form = document.getElementById('blogForm') as HTMLFormElement | null;
  form?.addEventListener('submit', () => {
    const btn = form.querySelector('[data-submit-btn]') as HTMLButtonElement | null;
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Menyimpan...';
    }
  });
</script>
