---
// Batch 3A-3 — Gallery item detail (read-only view). Mirrors
// /admin/tours/[id]/index.astro — same folder/URL convention as
// [id]/edit.astro.
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import StatusBadge from '@/components/admin/StatusBadge.astro';
import ConfirmDeleteModal from '@/components/shared/ConfirmDeleteModal.astro';
import { getGalleryItemById, listActivityLogs } from '@/services';
import { publicStorageUrl, formatDate } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const { id } = Astro.params;

const item = id ? await getGalleryItemById(supabase, id) : null;
if (!item) {
  return Astro.redirect('/admin/gallery?toast=' + encodeURIComponent('Foto galeri tidak ditemukan.') + '&toastType=error');
}

const logs = await listActivityLogs(supabase, { entity: 'gallery', entityId: item.id, perPage: 10 });
const imageUrl = item.image_url ? publicStorageUrl(supabase, item.image_url) : '';
---

<AdminLayout title={`Detail ${item.title}`}>
  <PageHeader title="Detail Foto Gallery" crumbs={[{ label: 'Konten' }, { label: 'Gallery', href: '/admin/gallery' }, { label: item.title }]}>
    <a href={`/admin/gallery/${item.id}/edit`} class="btn btn-primary me-2">
      <i class="bi bi-pencil me-1"></i> Edit
    </a>
    <a href="/admin/gallery" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Kembali
    </a>
  </PageHeader>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title mb-0">{item.title}</h5>
          <StatusBadge status="active" label="Aktif" />
        </div>
        <div class="card-body">
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Kategori</div>
            <div class="col-md-8">{item.category || <span class="text-muted">Tidak ada kategori</span>}</div>
          </div>
          <div class="row">
            <div class="col-md-4 text-muted small">Dibuat</div>
            <div class="col-md-8">{formatDate(item.created_at, true)}</div>
          </div>
        </div>
      </div>

      <div class="card mt-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Riwayat Aktivitas</h5>
        </div>
        <div class="card-body p-0">
          {logs.data.length === 0 ? (
            <p class="text-muted small p-3 mb-0">Belum ada aktivitas tercatat.</p>
          ) : (
            <ul class="list-group list-group-flush">
              {logs.data.map((log) => (
                <li class="list-group-item d-flex justify-content-between align-items-start">
                  <div>
                    <div class="fw-medium">{log.description ?? log.action}</div>
                    <div class="text-muted small">{log.actor_name ?? 'Sistem'}</div>
                  </div>
                  <span class="text-muted small">{formatDate(log.created_at, true)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Preview Foto</h5>
        </div>
        <div class="card-body">
          {imageUrl ? (
            <a href={imageUrl} target="_blank" rel="noopener noreferrer" title="Buka ukuran penuh">
              <img src={imageUrl} alt={item.title} class="img-fluid rounded-3" style="width:100%;object-fit:cover;" />
            </a>
          ) : (
            <div class="rounded-3 bg-secondary-subtle d-flex align-items-center justify-content-center" style="width:100%;height:180px;">
              <i class="bi bi-image text-secondary fs-1"></i>
            </div>
          )}
        </div>
      </div>

      <div class="card">
        <div class="card-body d-grid gap-2">
          <a href={`/admin/gallery/${item.id}/edit`} class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i> Edit Foto
          </a>
          <button
            type="button"
            class="btn btn-outline-danger"
            onclick={`openDeleteModal({ action: '/api/admin/gallery/${item.id}', label: '${item.title.replace(/'/g, "\\'")}' })`}
          >
            <i class="bi bi-trash3 me-1"></i> Hapus Foto
          </button>
        </div>
      </div>
    </div>
  </div>

  <ConfirmDeleteModal />
</AdminLayout>
