---
// Batch 3A-4 — Testimonial detail (read-only view + moderation actions +
// photo preview). Mirrors /admin/gallery/[id]/index.astro — same
// folder/URL convention as [id]/edit.astro.
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import StatusBadge from '@/components/admin/StatusBadge.astro';
import ConfirmDeleteModal from '@/components/shared/ConfirmDeleteModal.astro';
import { getTestimonialById, listActivityLogs } from '@/services';
import { publicStorageUrl, formatDate } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const { id } = Astro.params;

const testimonial = id ? await getTestimonialById(supabase, id) : null;
if (!testimonial) {
  return Astro.redirect('/admin/testimonials?toast=' + encodeURIComponent('Testimoni tidak ditemukan.') + '&toastType=error');
}

const logs = await listActivityLogs(supabase, { entity: 'testimonials', entityId: testimonial.id, perPage: 10 });
const photoUrl = testimonial.photo ? publicStorageUrl(supabase, testimonial.photo) : '';
const statusLabel = testimonial.status.charAt(0).toUpperCase() + testimonial.status.slice(1);

function stars(rating: number): string {
  const full = Math.round(rating);
  return '★★★★★☆☆☆☆☆'.slice(5 - full, 10 - full);
}
---

<AdminLayout title={`Detail Testimoni`}>
  <PageHeader title="Detail Testimoni" crumbs={[{ label: 'Konten' }, { label: 'Testimonials', href: '/admin/testimonials' }, { label: testimonial.name }]}>
    <a href={`/admin/testimonials/${testimonial.id}/edit`} class="btn btn-primary me-2">
      <i class="bi bi-pencil me-1"></i> Edit
    </a>
    <a href="/admin/testimonials" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Kembali
    </a>
  </PageHeader>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title mb-0">{testimonial.name}</h5>
          <StatusBadge status={testimonial.status} label={statusLabel} />
        </div>
        <div class="card-body">
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Pekerjaan</div>
            <div class="col-md-8">{testimonial.job || <span class="text-muted">Tidak diisi</span>}</div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Rating</div>
            <div class="col-md-8"><span class="text-warning">{stars(testimonial.rating)}</span> <span class="text-muted small">({testimonial.rating})</span></div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4 text-muted small">Pesan</div>
            <div class="col-md-8" style="white-space:pre-wrap;">{testimonial.message}</div>
          </div>
          <div class="row">
            <div class="col-md-4 text-muted small">Dikirim</div>
            <div class="col-md-8">{formatDate(testimonial.created_at, true)}</div>
          </div>
        </div>
      </div>

      <div class="card mt-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Riwayat Aktivitas</h5>
        </div>
        <div class="card-body p-0">
          {logs.data.length === 0 ? (
            <p class="text-muted small p-3 mb-0">Belum ada aktivitas tercatat.</p>
          ) : (
            <ul class="list-group list-group-flush">
              {logs.data.map((log) => (
                <li class="list-group-item d-flex justify-content-between align-items-start">
                  <div>
                    <div class="fw-medium">{log.description ?? log.action}</div>
                    <div class="text-muted small">{log.actor_name ?? 'Sistem'}</div>
                  </div>
                  <span class="text-muted small">{formatDate(log.created_at, true)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Preview Foto</h5>
        </div>
        <div class="card-body">
          {photoUrl ? (
            <a href={photoUrl} target="_blank" rel="noopener noreferrer" title="Buka ukuran penuh">
              <img src={photoUrl} alt={testimonial.name} class="img-fluid rounded-3" style="width:100%;object-fit:cover;" />
            </a>
          ) : (
            <div class="rounded-3 bg-secondary-subtle d-flex align-items-center justify-content-center" style="width:100%;height:180px;">
              <i class="bi bi-person text-secondary fs-1"></i>
            </div>
          )}
        </div>
      </div>

      <div class="card">
        <div class="card-body d-grid gap-2">
          {testimonial.status === 'approved' ? (
            <form method="post" action={`/api/admin/testimonials/${testimonial.id}/unapprove`}>
              <button type="submit" class="btn btn-outline-secondary w-100">
                <i class="bi bi-x-circle me-1"></i> Batalkan Persetujuan
              </button>
            </form>
          ) : (
            <form method="post" action={`/api/admin/testimonials/${testimonial.id}/approve`}>
              <button type="submit" class="btn btn-success w-100">
                <i class="bi bi-check-circle me-1"></i> Setujui Testimoni
              </button>
            </form>
          )}
          <a href={`/admin/testimonials/${testimonial.id}/edit`} class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i> Edit Testimoni
          </a>
          <button
            type="button"
            class="btn btn-outline-danger"
            onclick={`openDeleteModal({ action: '/api/admin/testimonials/${testimonial.id}', label: '${testimonial.name.replace(/'/g, "\\'")}' })`}
          >
            <i class="bi bi-trash3 me-1"></i> Hapus Testimoni
          </button>
        </div>
      </div>
    </div>
  </div>

  <ConfirmDeleteModal />
</AdminLayout>
