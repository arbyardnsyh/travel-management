---
// Batch 3A-4 — Testimonials trash (mirrors /admin/gallery/trash.astro pattern).
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/admin/PageHeader.astro';
import DataTable from '@/components/admin/DataTable.astro';
import EmptyState from '@/components/admin/EmptyState.astro';
import ConfirmDeleteModal from '@/components/shared/ConfirmDeleteModal.astro';
import { listTestimonials } from '@/services';
import { formatDate, publicStorageUrl } from '@/lib/helpers';

const supabase = Astro.locals.supabase;
const user = Astro.locals.user;
const searchParams = Astro.url.searchParams;

const q = searchParams.get('q') ?? '';
const page = Math.max(1, Number(searchParams.get('page') ?? 1) || 1);
const perPage = 10;

const { data: testimonials, count, totalPages } = await listTestimonials(supabase, {
  q: q || undefined,
  onlyDeleted: true,
  page,
  perPage,
});

const toast = searchParams.get('toast');
const toastType = searchParams.get('toastType') ?? 'success';
---

<AdminLayout title="Arsip Testimonials">
  <PageHeader title="Arsip Testimonials" crumbs={[{ label: 'Konten' }, { label: 'Testimonials', href: '/admin/testimonials' }, { label: 'Arsip' }]}>
    <a href="/admin/testimonials" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Kembali
    </a>
  </PageHeader>

  {toast && (
    <div class={`alert alert-${toastType === 'success' ? 'success' : 'danger'} d-flex align-items-center gap-2`}>
      <i class={`bi ${toastType === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle'}`}></i>
      {toast}
    </div>
  )}

  {testimonials.length === 0 && !q ? (
    <div class="card">
      <div class="card-body">
        <EmptyState icon="bi bi-trash3" title="Arsip kosong" text="Testimoni yang dihapus akan muncul di sini dan dapat dipulihkan kapan saja." />
      </div>
    </div>
  ) : (
    <DataTable
      columns={[
        { key: 'name', label: 'Nama' },
        { key: 'deleted_at', label: 'Diarsipkan' },
      ]}
      basePath="/admin/testimonials/trash"
      searchParams={searchParams}
      searchPlaceholder="Cari testimoni diarsipkan..."
      page={page}
      totalPages={totalPages}
      total={count}
      perPage={perPage}
      itemLabel="testimoni"
      isEmpty={testimonials.length === 0}
      emptyIcon="bi bi-search"
      emptyTitle="Tidak ditemukan"
      emptyText={`Tidak ada testimoni diarsipkan yang cocok dengan "${q}".`}
      actionsLabel="Aksi"
    >
      {testimonials.map((testimonial) => (
        <tr>
          <td>
            <div class="d-flex align-items-center gap-2">
              {testimonial.photo ? (
                <img
                  src={publicStorageUrl(supabase, testimonial.photo)}
                  alt={testimonial.name}
                  width="36"
                  height="36"
                  class="rounded-circle"
                  style="object-fit:cover;"
                />
              ) : (
                <div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                  <i class="bi bi-person text-secondary"></i>
                </div>
              )}
              <div class="fw-semibold text-muted">{testimonial.name}</div>
            </div>
          </td>
          <td class="users-meta">{formatDate(testimonial.deleted_at)}</td>
          <td class="text-center">
            <div class="users-actions">
              <form method="post" action={`/api/admin/testimonials/${testimonial.id}/restore`} class="d-inline">
                <button type="submit" class="users-action-btn" title="Pulihkan">
                  <i class="bi bi-arrow-counterclockwise"></i>
                </button>
              </form>
              {user?.role === 'admin' && (
                <button
                  type="button"
                  class="users-action-btn danger"
                  title="Hapus Permanen"
                  onclick={`openDeleteModal({ action: '/api/admin/testimonials/${testimonial.id}?permanent=1', label: '${testimonial.name.replace(/'/g, "\\'")} (permanen)' })`}
                >
                  <i class="bi bi-trash3-fill"></i>
                </button>
              )}
            </div>
          </td>
        </tr>
      ))}
    </DataTable>
  )}

  <ConfirmDeleteModal />
</AdminLayout>
