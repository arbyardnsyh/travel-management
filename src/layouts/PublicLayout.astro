---
import SeoHead from '@/components/SeoHead.astro';
import Header from '@/components/user/Header.astro';
import Footer from '@/components/user/Footer.astro';
import { supabase } from '@/lib/supabase';
import { publicStorageUrl } from '@/utils/storage';
import type { SiteSettings } from '@/lib/database.types';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  bodyClass?: string;
  noindex?: boolean;
}

// BUG FIX (Navbar transparent on every page, not just Home): this prop
// previously defaulted to '' but the <body> tag below fell back to
// 'index-page' whenever `bodyClass` was falsy — so every page that didn't
// explicitly pass its own bodyClass (i.e. every page except Home) silently
// rendered <body class="index-page"> too. That made it impossible to tell
// Home apart from any other page via CSS, which is what the new header-fix
// stylesheet below needs to do (see <!-- Main CSS --> section).
const { title, description, image, bodyClass = '', noindex = false } = Astro.props;

const { data: settingsRow } = await supabase
  .from('settings')
  .select('*')
  .maybeSingle<SiteSettings>();

// BUG FIX (Website Settings logo/favicon not updating on the frontend):
// `settings.logo` and `settings.favicon` are stored in the DB as Supabase
// Storage *paths* (e.g. "logo/172...-abc.png"), not public URLs — same
// convention as every other image column in the project (see
// ImageUploader.astro / utils/storage.ts:publicStorageUrl). The admin form's
// preview already resolves this correctly via `publicStorageUrl()`, but
// Header/Footer/<link rel="icon"> here were reading `settings.logo` /
// `settings.favicon` directly and rendering the raw storage path as an
// `<img src>` / `<link href>`, which the browser cannot load (hence "saved
// successfully but nothing changes on the frontend"). Resolving both to
// public URLs once here — and passing the resolved `settings` object down
// to <Header> and <Footer> — fixes the logo/favicon everywhere they're used
// without touching those components.
const settings: SiteSettings | null = settingsRow
  ? {
      ...settingsRow,
      logo: publicStorageUrl(supabase, settingsRow.logo) || null,
      favicon: publicStorageUrl(supabase, settingsRow.favicon) || null,
    }
  : null;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- BUG FIX (Bug 8 — SEO still using the old/default image instead of
         Website Settings): pages that don't pass their own `image` prop now
         fall back to the site logo from Website Settings (already resolved
         to a public URL above) instead of SeoHead's static default image,
         so OpenGraph/Twitter previews also stay in sync with the settings
         the admin uploads. -->
    <SeoHead title={`${title} | ${settings?.website_name || 'TravelTime'}`} description={description} image={image || settings?.logo || undefined} noindex={noindex} />

    <!-- Favicons -->
    <link href={settings?.favicon || '/assets-user/img/favicon.png'} rel="icon" />
    <link href="/assets-user/img/apple-touch-icon.png" rel="apple-touch-icon" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />

    <!-- Vendor CSS -->
    <link href="/assets-user/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/assets-user/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
    <link href="/assets-user/vendor/swiper/swiper-bundle.min.css" rel="stylesheet" />
    <link href="/assets-user/vendor/glightbox/css/glightbox.min.css" rel="stylesheet" />

    <!-- Main CSS -->
    <link href="/assets-user/css/main.css" rel="stylesheet" />

    <!-- Bug Fix: solid navbar on non-Home pages (Bug 5) — additive, loaded after main.css so it can override the transparent header on inner pages without touching the original template stylesheet. -->
    <link href="/assets-user/css/header-fix.css" rel="stylesheet" />
  </head>

  <body class={bodyClass}>
    <Header settings={settings ?? null} />

    <main class="main">
      <slot />
    </main>

    <Footer settings={settings ?? null} />

    <div id="preloader"></div>

    <!-- Vendor JS -->
    <script is:inline src="/assets-user/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/assets-user/vendor/php-email-form/validate.js"></script>
    <script is:inline src="/assets-user/vendor/purecounter/purecounter_vanilla.js"></script>
    <script is:inline src="/assets-user/vendor/swiper/swiper-bundle.min.js"></script>
    <script is:inline src="/assets-user/vendor/glightbox/js/glightbox.min.js"></script>
    <script is:inline src="/assets-user/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
    <script is:inline src="/assets-user/vendor/isotope-layout/isotope.pkgd.min.js"></script>

    <!-- Main JS -->
    <script is:inline src="/assets-user/js/main.js"></script>
  </body>
</html>
