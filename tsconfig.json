{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"]
    },
    "jsx": "preserve",
    "allowJs": true,
    "strictNullChecks": true
  },
  "exclude": ["node_modules", "dist", ".vercel", "public"]
}
