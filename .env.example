# =========================================================
# SUPABASE
# =========================================================
# Ambil dari: Supabase Dashboard > Project Settings > API
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service Role Key - HANYA dipakai di server (API routes / middleware).
# JANGAN PERNAH expose ke client / prefix PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =========================================================
# APP
# =========================================================
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_SITE_NAME=TravelTime

# Nama bucket Supabase Storage yang dipakai untuk seluruh upload gambar
PUBLIC_SUPABASE_STORAGE_BUCKET=media
